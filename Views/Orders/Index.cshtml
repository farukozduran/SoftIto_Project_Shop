@model IEnumerable<Project.Shop.Models.Order>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>
<section class="py-5">

    <div class="container px-4 px-lg-5 mt-5">
        <div class="row gx-4 gx-lg-5 row-cols-2 row-cols-md-3 row-cols-xl-4 justify-content-center">

        
            @foreach (var item in Model)
            {
                <div class="col mb-5">
                    <div class="card h-100">
                        <!-- Order details-->
                        <div class="card-body p-4">
                            <div class="text-center">
                                <!-- Order name-->
                                <h5 class="fw-bolder">@item.Customer.CustomerName</h5>
                                <!-- Price-->
                                <p>@item.Product.ProductName</p>
                            </div>
                        </div>
                        <!-- Order actions-->
                        <div class="card-footer p-4 pt-0 border-top-0 bg-transparent">
                            <a asp-action="Edit" asp-route-id="@item.OrderId" class="btn btn-success">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.OrderId" class="btn btn-danger">Delete</a>
                        </div>
                    </div>
                </div>
            }
        </div>

    </div>
</section>
@model IEnumerable<Project.Shop.Models.Category>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

<table class="table">

    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.CategoryName)</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <div class="col mb-5">
                <div class="card h-100">
                    <!-- Product image-->
                    <img class="card-img-top" src="https://thumbs.dreamstime.com/b/electronics-technology-line-art-thin-icons-set-computer-gadgets-vector-77815976.jpg" alt="..." />
                    <!-- Product details-->
                    <div class="card-body p-4">
                        <div class="text-center">
                            <!-- Category name-->
                            <h5 class="fw-bolder">@Html.DisplayFor(modelItem => item.CategoryName)</h5>
                            <!-- Motto-->
                            Teknolojinin en yeni ürünleri burada.
                        </div>
                    </div>
                    <!-- Product actions-->
                    <div class="card-footer p-4 pt-0 border-top-0 bg-transparent">
                        <div class="text-center"><a class="btn btn-outline-dark mt-auto" href="#">Ürünlere git</a></div>
                        <a asp-action="Edit" asp-route-id="@item.CategoryId" class="btn btn-success">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.CategoryId" class="btn btn-danger">Delete</a>
                    </div>
                </div>
            </div>
            <tr>
                <td>@Html.DisplayFor(modelItem => item.CategoryName)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.CategoryId" class="btn btn-success">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.CategoryId" class="btn btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>

</table>
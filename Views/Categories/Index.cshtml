@model IEnumerable<Project.Shop.Models.Category>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>
<section class="py-5">
    
    <div class="container px-4 px-lg-5 mt-5">
        <div class="row gx-4 gx-lg-5 row-cols-2 row-cols-md-3 row-cols-xl-4 justify-content-center">
        
    
        @foreach (var item in Model)
        {
            <div class="col mb-5">
                <div class="card h-100">
                    <!-- Product image-->
                    <img class="card-img-top" src="@Html.DisplayFor(modelItem => item.ImageUrl)" alt="..." />
                    <!-- Product details-->
                    <div class="card-body p-4">
                        <div class="text-center">
                            <!-- Category name-->
                            <h5 class="fw-bolder">@Html.DisplayFor(modelItem => item.CategoryName)</h5>
                            <!-- Motto-->
                            <p class="text-muted">@Html.DisplayFor(modelItem => item.Tagline)</p>
                        </div>
                    </div>
                    <!-- Product actions-->
                    <div class="card-footer p-4 pt-0 border-top-0 bg-transparent">
                        <div class="text-center"><a class="btn btn-outline-dark mt-auto" href="#">Ürünlere git</a></div>
                        <a asp-action="Edit" asp-route-id="@item.CategoryId" class="btn btn-success">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.CategoryId" class="btn btn-danger">Delete</a>
                    </div>
                </div>
            </div>
            }
        </div>
        
    </div>
</section>


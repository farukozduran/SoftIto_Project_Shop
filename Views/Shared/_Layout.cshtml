<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="" />
    <meta name="author" content="" />
    <title>Faruk's Shop</title>
    <!-- Favicon-->
    <link rel="icon" type="image/x-icon" href="~/assets/favicon.ico" />
    <!-- Bootstrap icons-->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.5.0/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- Core theme CSS (includes Bootstrap)-->
    <link href="~/css/styles.css" rel="stylesheet" />
    <style>
            .custom-navbar {
                background: rgba(17, 24, 39, 0.96);
                backdrop-filter: blur(14px);
                box-shadow: 0 12px 35px rgba(17, 24, 39, 0.18);
                padding: 14px 0;
                z-index: 999;
            }

            .custom-brand {
                display: flex;
                align-items: center;
                gap: 10px;
                color: #ffffff !important;
                font-weight: 800;
                font-size: 22px;
                letter-spacing: -0.4px;
                text-decoration: none;
            }

            .brand-icon {
                width: 42px;
                height: 42px;
                border-radius: 14px;
                background: #ffffff;
                color: #111827;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 22px;
                box-shadow: 0 8px 24px rgba(255, 255, 255, 0.12);
            }

            .custom-nav-link {
                color: #d1d5db !important;
                font-weight: 600;
                padding: 10px 14px !important;
                border-radius: 999px;
                transition: all .25s ease;
            }

                .custom-nav-link:hover,
                .custom-nav-link:focus {
                    color: #ffffff !important;
                    background: rgba(255, 255, 255, 0.10);
                }

            .custom-dropdown {
                border: 0;
                border-radius: 18px;
                padding: 10px;
                margin-top: 12px;
                box-shadow: 0 18px 45px rgba(17, 24, 39, 0.20);
            }

            .custom-dropdown-item {
                border-radius: 12px;
                padding: 10px 14px;
                font-weight: 600;
                color: #374151;
                transition: all .2s ease;
            }

                .custom-dropdown-item:hover {
                    background: #111827;
                    color: #ffffff;
                }

            .custom-shop-btn {
                border-radius: 999px;
                font-weight: 700;
                padding: 9px 18px;
                color: #111827;
                border: 0;
                box-shadow: 0 8px 24px rgba(255, 255, 255, 0.10);
            }

                .custom-shop-btn:hover {
                    background: #f3f4f6;
                    color: #111827;
                }

            .custom-admin-btn {
                border-radius: 999px;
                font-weight: 700;
                padding: 9px 18px;
                color: #ffffff;
                border: 1px solid rgba(255, 255, 255, 0.25);
                background: rgba(255, 255, 255, 0.08);
            }

                .custom-admin-btn:hover {
                    background: #ffffff;
                    color: #111827;
                }

            .custom-toggler {
                border: 1px solid rgba(255, 255, 255, 0.25);
                background: #ffffff;
                border-radius: 12px;
                padding: 8px 10px;
            }

            @@media (max-width: 991px) {
                .navbar-nav {
                    margin-top: 18px;
                    padding: 12px;
                    background: rgba(255, 255, 255, 0.06);
                    border-radius: 18px;
                }

                .custom-nav-link {
                    border-radius: 12px;
                }

                .custom-dropdown {
                    margin-top: 6px;
                    box-shadow: none;
                }

                .custom-shop-btn,
                .custom-admin-btn {
                    width: 100%;
                    margin-top: 10px;
                }

                .d-flex.align-items-center.gap-2 {
                    flex-direction: column;
                    align-items: stretch !important;
                    margin-top: 12px;
                }
            }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg custom-navbar sticky-top">
        <div class="container px-4 px-lg-5">

            <a class="navbar-brand custom-brand" asp-controller="Home" asp-action="Index">
                <span class="brand-icon">
                    <i class="bi bi-bag-check"></i>
                </span>
                <span>Faruk's Shop</span>
            </a>

            <button class="navbar-toggler custom-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">

                <ul class="navbar-nav mx-auto mb-2 mb-lg-0">

                    <!-- Products -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle custom-nav-link"
                           id="productsDropdown"
                           href="#"
                           role="button"
                           data-bs-toggle="dropdown"
                           aria-expanded="false">
                            <i class="bi bi-box-seam me-1"></i>
                            Ürünler
                        </a>

                        <ul class="dropdown-menu custom-dropdown" aria-labelledby="productsDropdown">
                            <li>
                                <a class="dropdown-item custom-dropdown-item"
                                   asp-controller="Products"
                                   asp-action="Index">
                                    <i class="bi bi-grid me-2"></i>
                                    Bütün Ürünler
                                </a>
                            </li>

                            <li><hr class="dropdown-divider" /></li>

                            <li>
                                <a class="dropdown-item custom-dropdown-item"
                                   asp-controller="Products"
                                   asp-action="Create">
                                    <i class="bi bi-plus-circle me-2"></i>
                                    Ürün Ekle
                                </a>
                            </li>
                        </ul>
                    </li>

                    <!-- Categories -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle custom-nav-link"
                           id="categoriesDropdown"
                           href="#"
                           role="button"
                           data-bs-toggle="dropdown"
                           aria-expanded="false">
                            <i class="bi bi-tags me-1"></i>
                            Kategoriler
                        </a>

                        <ul class="dropdown-menu custom-dropdown" aria-labelledby="categoriesDropdown">
                            <li>
                                <a class="dropdown-item custom-dropdown-item"
                                   asp-controller="Categories"
                                   asp-action="Index">
                                    <i class="bi bi-collection me-2"></i>
                                    Bütün Kategoriler
                                </a>
                            </li>

                            <li><hr class="dropdown-divider" /></li>

                            <li>
                                <a class="dropdown-item custom-dropdown-item"
                                   asp-controller="Categories"
                                   asp-action="Create">
                                    <i class="bi bi-plus-circle me-2"></i>
                                    Kategori Ekle
                                </a>
                            </li>
                        </ul>
                    </li>

                    <!-- Customers -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle custom-nav-link"
                           id="customersDropdown"
                           href="#"
                           role="button"
                           data-bs-toggle="dropdown"
                           aria-expanded="false">
                            <i class="bi bi-people me-1"></i>
                            Müşteriler
                        </a>

                        <ul class="dropdown-menu custom-dropdown" aria-labelledby="customersDropdown">
                            <li>
                                <a class="dropdown-item custom-dropdown-item"
                                   asp-controller="Customers"
                                   asp-action="Index">
                                    <i class="bi bi-person-lines-fill me-2"></i>
                                    Bütün Müşteriler
                                </a>
                            </li>

                            <li><hr class="dropdown-divider" /></li>

                            <li>
                                <a class="dropdown-item custom-dropdown-item"
                                   asp-controller="Customers"
                                   asp-action="Create">
                                    <i class="bi bi-person-plus me-2"></i>
                                    Müşteri Ekle
                                </a>
                            </li>
                        </ul>
                    </li>

                    <!-- Orders -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle custom-nav-link"
                           id="ordersDropdown"
                           href="#"
                           role="button"
                           data-bs-toggle="dropdown"
                           aria-expanded="false">
                            <i class="bi bi-receipt me-1"></i>
                            Siparişler
                        </a>

                        <ul class="dropdown-menu custom-dropdown" aria-labelledby="ordersDropdown">
                            <li>
                                <a class="dropdown-item custom-dropdown-item"
                                   asp-controller="Orders"
                                   asp-action="Index">
                                    <i class="bi bi-card-list me-2"></i>
                                    Bütün Siparişler
                                </a>
                            </li>

                            <li><hr class="dropdown-divider" /></li>

                            <li>
                                <a class="dropdown-item custom-dropdown-item"
                                   asp-controller="Orders"
                                   asp-action="Create">
                                    <i class="bi bi-plus-circle me-2"></i>
                                    Sipariş Ekle
                                </a>
                            </li>
                        </ul>
                    </li>

                </ul>

                <div class="d-flex align-items-center gap-2">
                    <a asp-controller="Products"
                       asp-action="Index"
                       class="btn btn-light custom-shop-btn">
                        <i class="bi bi-bag me-1"></i>
                        Alışverişe Başla
                    </a>

                    <a asp-controller="Admin"
                       asp-action="Index"
                       class="btn custom-admin-btn">
                        <i class="bi bi-lock me-1"></i>
                        Admin
                    </a>
                </div>

            </div>
        </div>
    </nav>
    <!-- Section-->
    <section class="py-5">
        <div class="container px-4 px-lg-5 mt-5">
            @RenderBody()
        </div>
    </section>
    <!-- Footer-->
    <footer class="py-5 bg-dark">
        <div class="container"><p class="m-0 text-center text-white">Tüm hakları saklıdır. &copy; Faruk Furkan Özduran 2026</p></div>
    </footer>
    <!-- Bootstrap core JS-->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Core theme JS-->
    <script src="~/js/scripts.js"></script>
</body>
</html>
